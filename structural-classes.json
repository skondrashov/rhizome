{
  "classes": {
    "hub-and-spoke": {
      "label": "Hub-and-Spoke",
      "description": "A central orchestrator with full visibility dispatches work to and collects results from peripheral specialist agents who do not communicate with each other.",
      "color": "#E63946"
    },
    "strict-hierarchy": {
      "label": "Strict Hierarchy",
      "description": "A multi-layered tree where orders flow top-down and reports flow bottom-up through fixed ranks, with no level skipping.",
      "color": "#5B8FB9"
    },
    "mentor-apprentice": {
      "label": "Mentor-Apprentice",
      "description": "An experienced lead transfers knowledge and authority progressively to junior agents through supervised practice and graduated autonomy.",
      "color": "#29B6F6"
    },
    "peer-ensemble": {
      "label": "Peer Ensemble",
      "description": "A small group of roughly equal, skilled agents collaborate fluidly with emergent leadership and no fixed hierarchy.",
      "color": "#2A9D8F"
    },
    "assembly-pipeline": {
      "label": "Assembly Pipeline",
      "description": "Work flows sequentially through specialized stations, each transforming the artifact before passing it to the next stage.",
      "color": "#E9C46A"
    },
    "compartmented-cells": {
      "label": "Compartmented Cells",
      "description": "Small isolated groups connected only through intermediaries, maximizing operational security through strict information barriers.",
      "color": "#5E9BA0"
    },
    "federation-of-sovereigns": {
      "label": "Federation of Sovereigns",
      "description": "Autonomous subgroups with full internal authority coordinate through liaison bridges, shared protocols, or a thin federal layer.",
      "color": "#F4A261"
    },
    "democratic-assembly": {
      "label": "Democratic Assembly",
      "description": "All agents participate as equals in collective decision-making through voting, deliberation, or consent-based governance.",
      "color": "#E76F51"
    },
    "adversarial-arena": {
      "label": "Adversarial Arena",
      "description": "Opposing agents compete or argue before a neutral judge or evaluator, with truth or quality emerging from structured conflict.",
      "color": "#E05555"
    },
    "swarm-stigmergy": {
      "label": "Swarm-Stigmergy",
      "description": "Many simple, interchangeable agents coordinate indirectly through environmental signals, producing emergent collective intelligence without central control.",
      "color": "#7CB342"
    },
    "triage-and-dispatch": {
      "label": "Triage-and-Dispatch",
      "description": "A gatekeeper classifies incoming work by priority or type and routes it to appropriate specialist agents for processing.",
      "color": "#BC6C25"
    },
    "dual-key-safeguard": {
      "label": "Dual-Key Safeguard",
      "description": "Multiple independent agents must concur or verify before high-stakes actions proceed, with built-in veto and audit mechanisms.",
      "color": "#CC4466"
    },
    "creative-atelier": {
      "label": "Creative Atelier",
      "description": "A vision-holder directs specialized departments that each contribute distinct expertise to a unified creative output through iterative review.",
      "color": "#C77DFF"
    },
    "market-ecosystem": {
      "label": "Market Ecosystem",
      "description": "Agents interact through competitive or exchange mechanisms -- bidding, trading, reputation scoring -- with prices or signals aggregating distributed information.",
      "color": "#FFB703"
    },
    "cyclic-renewal": {
      "label": "Cyclic Renewal",
      "description": "Agents rotate through phases, roles, or generations, with the system's identity persisting through continuous turnover and knowledge transfer.",
      "color": "#8338EC"
    }
  },
